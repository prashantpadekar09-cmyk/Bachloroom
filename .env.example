# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyAJi1djsOVIgNXyupBvwmNl3av88WijHjY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Authentication
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Supabase Postgres (recommended for persistence on hosting)
# Use the "Connection string" from Supabase -> Project Settings -> Database.
# Example: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL=

# Set to "false" only if your connection string does not require TLS.
SUPABASE_DB_SSL=true
